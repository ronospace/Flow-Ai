{
  "name": "flow-ai-receipt-service",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24"
  },
  "main": "lib/index.js",
  "scripts": {
    "clean": "rm -rf lib",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc",
    "test": "npm run build && node --test test/*.test.mjs",
    "smoke": "node -e \"import('./lib/index.js').then((m) => { if (m.runtimeArchitecture !== 'minimal-cloud-run') process.exit(1); console.log('SMOKE=PASS'); })\"",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run smoke",
    "start": "node lib/index.js"
  },
  "dependencies": {
    "@apple/app-store-server-library": "3.1.0",
    "jose": "6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "24.13.1",
    "eslint": "10.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.61.0"
  }
}
