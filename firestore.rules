rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /partnerInvites/{inviteId} {
      allow read, write: if false;
    }

    match /partnerConnections/{connectionId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
